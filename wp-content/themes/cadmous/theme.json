{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "1280px",
            "wideSize": "1440px"
        },
        "color": {
            "background": true,
            "custom": false,
            "customDuotone": false,
            "customGradient": false,
            "defaultDuotone": false,
            "defaultGradients": false,
            "defaultPalette": false,
            "link": true,
            "text": true,
            "palette": [
                {
                    "slug": "navy",
                    "name": "Navy",
                    "color": "#1B365D"
                },
                {
                    "slug": "gold",
                    "name": "Gold",
                    "color": "#C4933F"
                },
                {
                    "slug": "warm-white",
                    "name": "Warm White",
                    "color": "#FAFAF7"
                },
                {
                    "slug": "cream",
                    "name": "Cream",
                    "color": "#F0EDE6"
                },
                {
                    "slug": "ink",
                    "name": "Ink",
                    "color": "#1A1A1A"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#6B7280"
                },
                {
                    "slug": "border",
                    "name": "Border",
                    "color": "#E5E1D8"
                },
                {
                    "slug": "success",
                    "name": "Success",
                    "color": "#2D6A4F"
                },
                {
                    "slug": "warning",
                    "name": "Warning",
                    "color": "#D4A017"
                },
                {
                    "slug": "error",
                    "name": "Error",
                    "color": "#C1292E"
                },
                {
                    "slug": "info",
                    "name": "Info",
                    "color": "#1B365D"
                }
            ]
        },
        "typography": {
            "customFontSize": false,
            "dropCap": false,
            "fluid": true,
            "fontStyle": true,
            "fontWeight": true,
            "letterSpacing": true,
            "lineHeight": true,
            "textDecoration": true,
            "textTransform": true,
            "writingMode": false,
            "fontFamilies": [
                {
                    "slug": "fraunces",
                    "name": "Fraunces",
                    "fontFamily": "Fraunces, Georgia, \"Times New Roman\", serif",
                    "fontFace": [
                        {
                            "fontFamily": "Fraunces",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/fraunces-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Fraunces",
                            "fontStyle": "normal",
                            "fontWeight": "500",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/fraunces-500.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Fraunces",
                            "fontStyle": "normal",
                            "fontWeight": "600",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/fraunces-600.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Fraunces",
                            "fontStyle": "normal",
                            "fontWeight": "700",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/fraunces-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "dm-sans",
                    "name": "DM Sans",
                    "fontFamily": "\"DM Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
                    "fontFace": [
                        {
                            "fontFamily": "DM Sans",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/dm-sans-400.woff2"
                            ]
                        },
                        {
                            "fontFamily": "DM Sans",
                            "fontStyle": "normal",
                            "fontWeight": "500",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/dm-sans-500.woff2"
                            ]
                        },
                        {
                            "fontFamily": "DM Sans",
                            "fontStyle": "normal",
                            "fontWeight": "700",
                            "fontDisplay": "swap",
                            "src": [
                                "file:./assets/fonts/dm-sans-700.woff2"
                            ]
                        }
                    ]
                },
                {
                    "slug": "system",
                    "name": "System",
                    "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif"
                }
            ],
            "fontSizes": [
                {
                    "slug": "caption",
                    "name": "Caption",
                    "size": "0.75rem",
                    "fluid": false
                },
                {
                    "slug": "small",
                    "name": "Small",
                    "size": "0.875rem",
                    "fluid": false
                },
                {
                    "slug": "body",
                    "name": "Body",
                    "size": "1.0625rem",
                    "fluid": false
                },
                {
                    "slug": "large",
                    "name": "Large",
                    "size": "1.25rem",
                    "fluid": {
                        "min": "1.125rem",
                        "max": "1.25rem"
                    }
                },
                {
                    "slug": "h3",
                    "name": "Heading 3",
                    "size": "1.5rem",
                    "fluid": {
                        "min": "1.375rem",
                        "max": "1.5rem"
                    }
                },
                {
                    "slug": "h2",
                    "name": "Heading 2",
                    "size": "2.25rem",
                    "fluid": {
                        "min": "1.75rem",
                        "max": "2.25rem"
                    }
                },
                {
                    "slug": "h1",
                    "name": "Heading 1",
                    "size": "3rem",
                    "fluid": {
                        "min": "2.25rem",
                        "max": "3rem"
                    }
                },
                {
                    "slug": "hero",
                    "name": "Hero",
                    "size": "4rem",
                    "fluid": {
                        "min": "2.75rem",
                        "max": "4rem"
                    }
                }
            ]
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "units": [
                "px",
                "em",
                "rem",
                "%",
                "vh",
                "vw"
            ],
            "spacingScale": {
                "steps": 0
            },
            "spacingSizes": [
                {
                    "slug": "2xs",
                    "name": "2XS (2px)",
                    "size": "2px"
                },
                {
                    "slug": "xs",
                    "name": "XS (4px)",
                    "size": "4px"
                },
                {
                    "slug": "sm",
                    "name": "SM (8px)",
                    "size": "8px"
                },
                {
                    "slug": "md",
                    "name": "MD (16px)",
                    "size": "16px"
                },
                {
                    "slug": "lg",
                    "name": "LG (24px)",
                    "size": "24px"
                },
                {
                    "slug": "xl",
                    "name": "XL (32px)",
                    "size": "32px"
                },
                {
                    "slug": "2xl",
                    "name": "2XL (48px)",
                    "size": "48px"
                },
                {
                    "slug": "3xl",
                    "name": "3XL (64px)",
                    "size": "64px"
                },
                {
                    "slug": "4xl",
                    "name": "4XL (96px)",
                    "size": "96px"
                },
                {
                    "slug": "5xl",
                    "name": "5XL (128px)",
                    "size": "128px"
                }
            ]
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "shadow": {
            "defaultPresets": false,
            "presets": [
                {
                    "slug": "sm",
                    "name": "Small",
                    "shadow": "0 1px 2px rgba(26, 26, 26, 0.06)"
                },
                {
                    "slug": "md",
                    "name": "Medium",
                    "shadow": "0 4px 12px rgba(26, 26, 26, 0.08)"
                },
                {
                    "slug": "lg",
                    "name": "Large",
                    "shadow": "0 12px 32px rgba(26, 26, 26, 0.12)"
                }
            ]
        },
        "custom": {
            "radii": {
                "sm": "6px",
                "md": "12px",
                "lg": "20px",
                "full": "9999px"
            },
            "transition": {
                "micro": "100ms ease-out",
                "short": "200ms ease-out",
                "medium": "350ms ease-in-out",
                "long": "500ms ease-in-out"
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--warm-white)",
            "text": "var(--wp--preset--color--ink)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--dm-sans)",
            "fontSize": "var(--wp--preset--font-size--body)",
            "lineHeight": "1.6"
        },
        "spacing": {
            "padding": {
                "top": "0",
                "right": "var(--wp--preset--spacing--lg)",
                "bottom": "0",
                "left": "var(--wp--preset--spacing--lg)"
            },
            "blockGap": "var(--wp--preset--spacing--lg)"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fraunces)",
                    "fontWeight": "600",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.01em"
                },
                "color": {
                    "text": "var(--wp--preset--color--ink)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--hero)",
                    "lineHeight": "1.1"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--h1)",
                    "lineHeight": "1.15"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--h2)",
                    "lineHeight": "1.2"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--h3)",
                    "lineHeight": "1.3"
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--navy)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--gold)"
                    }
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--gold)",
                    "text": "var(--wp--preset--color--ink)"
                },
                "border": {
                    "radius": "12px"
                },
                "spacing": {
                    "padding": {
                        "top": "var(--wp--preset--spacing--md)",
                        "right": "var(--wp--preset--spacing--xl)",
                        "bottom": "var(--wp--preset--spacing--md)",
                        "left": "var(--wp--preset--spacing--xl)"
                    }
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--dm-sans)",
                    "fontSize": "var(--wp--preset--font-size--body)",
                    "fontWeight": "600",
                    "letterSpacing": "0.01em"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--navy)",
                        "text": "var(--wp--preset--color--warm-white)"
                    }
                }
            }
        },
        "blocks": {
            "core/paragraph": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--dm-sans)",
                    "lineHeight": "1.6"
                }
            },
            "core/quote": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fraunces)",
                    "fontStyle": "italic",
                    "fontSize": "var(--wp--preset--font-size--large)"
                },
                "border": {
                    "color": "var(--wp--preset--color--gold)",
                    "style": "solid",
                    "width": "0 0 0 4px"
                },
                "spacing": {
                    "padding": {
                        "left": "var(--wp--preset--spacing--lg)"
                    }
                }
            },
            "core/heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fraunces)"
                }
            },
            "core/pullquote": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--fraunces)"
                },
                "border": {
                    "color": "var(--wp--preset--color--gold)"
                }
            },
            "core/separator": {
                "color": {
                    "background": "var(--wp--preset--color--border)"
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "page-no-header",
            "title": "Page — no header",
            "postTypes": [
                "page"
            ]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "topbar",
            "title": "Top bar (language switcher + Apply CTA)",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}
