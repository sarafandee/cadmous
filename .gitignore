# Secrets
.env
.env.local
.env.*.local

# Docker volumes (if ever bind-mounted during debugging)
wordpress_data/
db_data/

# WordPress runtime state — only commit the directory stubs, not the contents
wp-content/upgrade/
wp-content/cache/
wp-content/backup*/
wp-content/debug.log

# Plugins: ignore everything except the index.php silence stub
wp-content/plugins/*
!wp-content/plugins/index.php

# Uploads: ignore everything except the index.php silence stub
wp-content/uploads/*
!wp-content/uploads/index.php

# mu-plugins: ignored entirely (not used v1)
wp-content/mu-plugins/

# Themes: only commit the cadmous theme
wp-content/themes/*
!wp-content/themes/cadmous/

# Theme build output
wp-content/themes/cadmous/node_modules/
wp-content/themes/cadmous/vendor/
wp-content/themes/cadmous/build/
wp-content/themes/cadmous/dist/
wp-content/themes/cadmous/.phpcs-cache
wp-content/themes/cadmous/*.log

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Claude Code local overrides
.claude/settings.local.json
.gstack/
