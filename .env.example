# --- Database (required) ---
DB_NAME=cadmous
DB_USER=cadmous
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme-root
WP_TABLE_PREFIX=wp_

# --- WP admin seed credentials (optional, bootstrap.sh defaults to admin/admin) ---
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin
WP_ADMIN_EMAIL=admin@cadmous.edu.lb
WP_SITE_URL=http://localhost:8080

# --- ACF Pro license (optional) ---
# Get this from https://advancedcustomfields.com/my-account/. When set,
# bin/bootstrap.sh will install ACF Pro via the authorized download URL.
# Leave empty to skip ACF Pro.
ACF_LICENSE_KEY=

# --- WP Mail SMTP / Microsoft 365 (CAD-17) ---
# Off by default. Turn on by setting WPMS_ON=true and filling in the
# M365_* values after running through docs/cad-17-smtp-setup.md.
WPMS_ON=false
WPMS_MAIL_FROM=noreply@cadmous.edu.lb
WPMS_MAIL_FROM_NAME=Cadmous College
WPMS_MAILER=mail
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
